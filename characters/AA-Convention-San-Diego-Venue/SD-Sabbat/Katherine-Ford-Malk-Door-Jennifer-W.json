        ],
        [
          "Yasmin the Black",
          "This False Hand Tremere Antritrbu created the ritual that destroyed all of the Camarilla Warlocks in San Diego"
        ],
        [
          "Willis Grant",
          "A vain lasombra Pack Leader of the Fifth Ward, he clings to his mortal religion"
        ],
        [
          "Dawn Alabastor",
          "A Ventrue Antitribu ductus of the Labrys Rune with a penchant for secrets and mazes"
        ],
        [
          "Elvira",
          "An ancient vampire and ambitious Lasombra.  If she could be trusted she'd make an excellent addition to the True Hand.  She leads Cardine Scorso"
