        [
          "Kinyado",
          "An Inquisitor who hopes to tear down the Tremere Chantry and bury all the forbidden secrets within it"
        ],
        [
          "Chalupavka",
          "Rival for Archbishop: A monstrous Tzimsce Elder from Peru.  She is said to be a deadly and unstable warrior"
        ],
